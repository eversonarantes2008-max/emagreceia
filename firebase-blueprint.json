{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account profile tracking health metrics, checklist completions, generated 30-day coaching plans, and premium subscription payment state.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "streakDays": {
          "type": "number"
        },
        "currentWeight": {
          "type": "number"
        },
        "isPremium": {
          "type": "boolean"
        },
        "premiumStatus": {
          "type": "string",
          "enum": ["none", "pending", "approved"]
        },
        "premiumPasswordSent": {
          "type": "string"
        },
        "hasEnteredPremiumPassword": {
          "type": "boolean"
        }
      },
      "required": ["uid", "email", "createdAt", "streakDays", "currentWeight"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles database mapping authenticated UIDs to their specific metrics and plan definitions."
    }
  }
}
